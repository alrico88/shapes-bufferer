{
  "name": "shapes-bufferer",
  "version": "2.0.1",
  "description": "Helper classes to add a buffer to a GeoJSON or BBox",
  "keywords": [
    "bbox",
    "buffer",
    "geohash",
    "geojson",
    "shape"
  ],
  "license": "MIT",
  "author": "Alberto Rico",
  "repository": {
    "url": "https://github.com/alrico88/shapes-bufferer"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "test": "vp test",
    "coverage": "vp test --coverage",
    "lint": "vp lint",
    "docs": "typedoc",
    "prepublish": "vp pack",
    "coveralls": "vp test --coverage && cat ./coverage/lcov.info | ./node_modules/coveralls/bin/coveralls.js",
    "prepare": "vp config"
  },
  "dependencies": {
    "@turf/buffer": "^6.5.0",
    "@turf/difference": "6.5.0",
    "@turf/union": "6.5.0",
    "bbox-helper-functions": "^3.2.4"
  },
  "devDependencies": {
    "@turf/boolean-contains": "^6.5.0",
    "@turf/helpers": "^6.5.0",
    "@types/geojson": "^7946.0.8",
    "coveralls": "^3.1.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.7.0"
}
